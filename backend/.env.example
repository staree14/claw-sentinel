# ═══════════════════════════════════════════════
# ClawSentinel — Environment Configuration
# Copy this to .env and fill in your real values
# NEVER commit the real .env to git
# ═══════════════════════════════════════════════

# ───────────────────────────────────────────────
# App Settings
# ───────────────────────────────────────────────
APP_ENV=development
HOST=0.0.0.0
PORT=8000

# ───────────────────────────────────────────────
# Memory File Paths (SOUL.md & HEARTBEAT.md)
# ───────────────────────────────────────────────
SOUL_MD_PATH=./memory/SOUL.md
HEARTBEAT_MD_PATH=./memory/HEARTBEAT.md

# ───────────────────────────────────────────────
# ML Model Path (run ml/train_model.py first)
# ───────────────────────────────────────────────
MODEL_PATH=../ml/model.pkl

# ───────────────────────────────────────────────
# Google Gemini API (Decision Agent — Real LLM)
# Get yours at: https://aistudio.google.com/apikey
# Free tier available
# ───────────────────────────────────────────────
GEMINI_API_KEY=your_gemini_api_key_here
GEMINI_MODEL=gemini-1.5-flash

# ───────────────────────────────────────────────
# Telegram Bot (Action Agent — Real Notifications)
# HOW TO GET:
#   1. Open Telegram → search @BotFather
#   2. Send /newbot → follow steps → copy the token below
#   3. Message your bot once (click Start)
#   4. Get your CHAT_ID by messaging @userinfobot on Telegram
# ───────────────────────────────────────────────
TELEGRAM_BOT_TOKEN=your_bot_token_from_botfather_here
TELEGRAM_CHAT_ID=your_personal_chat_id_here

# ───────────────────────────────────────────────
# OpenClaw Integration (Orchestration Layer)
# Run AFTER installing OpenClaw:
#   openclaw config set plugins.entries.telegram.enabled true
#   openclaw channels add --channel telegram --token "YOUR_TELEGRAM_BOT_TOKEN"
# These are set here for reference only — OpenClaw reads its own config
# ───────────────────────────────────────────────
OPENCLAW_ENABLED=true
OPENCLAW_WORKSPACE_PATH=~/.openclaw/workspace
